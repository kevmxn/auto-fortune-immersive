BEGIN TRANSACTION;
CREATE TABLE IF NOT EXISTS "roulette_1" (
	"id"	INTEGER,
	"spin_number"	INTEGER NOT NULL,
	"timestamp"	DATETIME DEFAULT CURRENT_TIMESTAMP,
	"game_id"	TEXT,
	UNIQUE("game_id"),
	PRIMARY KEY("id" AUTOINCREMENT)
);
CREATE TABLE IF NOT EXISTS "russian_roulette" (
	"id"	INTEGER,
	"spin_number"	INTEGER NOT NULL,
	"timestamp"	DATETIME DEFAULT CURRENT_TIMESTAMP,
	"game_id"	TEXT,
	UNIQUE("game_id"),
	PRIMARY KEY("id" AUTOINCREMENT)
);
